{
    "name": "survos/state-bundle",
    "description": "Add some tools managing state machines using the Symfony Workflow Component",
    "keywords": [
        "symfony",
        "symfony-ux",
        "workflow"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "type": "symfony-bundle",
    "require": {
        "php": "^8.5",
        "doctrine/orm": "^2.12 || ^3.3",
        "symfony/console": "^8.1",
        "symfony/http-kernel": "^8.1",
        "symfony/messenger": "^8.1",
        "symfony/process": "^8.1",
        "symfony/workflow": "^8.1",
        "symfony/yaml": "^8.1",
        "survos/kit-bundle": "^2.5",
        "symfony/string": "^8.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "symfony/browser-kit": "^8.1",
        "symfony/config": "^8.1",
        "symfony/dependency-injection": "^8.1",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/maker-bundle": "^1.5",
        "symfony/twig-bundle": "^8.1",
        "symfony/var-dumper": "^8.1",
        "zenstruck/class-metadata": "^1.1",
        "psr/log": "^3.0",
        "nette/php-generator": "^4.1",
        "phpunit/phpunit": "^13.0",
        "roave/better-reflection": "^6.0",
        "zenstruck/messenger-monitor-bundle": "^v0.6.0",
        "symfony/ux-chartjs": "^3",
        "survos/tabler-bundle": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Survos\\StateBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Survos\\StateBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        },
        "branch-alias": {
            "dev-master": "2.1-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "zenstruck/class-metadata": true
        }
    },
    "prefer-stable": true
}