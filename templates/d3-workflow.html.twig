{% extends ['base.html.twig', '@SurvosState/layout.html.twig'] %}

{% block page_title "%s Workflow"|format(flowCode) %}
{% block page_subtitle "Place count?" %}

{# ux icon lock issue #}
    {% set iterateCommand = 'state:iterate' %}
{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Graph fills its card; the card fills the viewport beside the sidebar. */
        .workflow-graph-card { height: calc(100vh - 9rem); min-height: 28rem; display: flex; flex-direction: column; }
        /* card-body must be a flex child that can shrink, so the graph gets a real height to scale into */
        .workflow-graph-card > .card-body { flex: 1 1 auto; min-height: 0; }
        .workflow-graph { width: 100%; height: 100%; overflow: hidden; }
        .workflow-graph svg { display: block; width: 100%; height: 100%; }
        /* native tooltips for nodes/edges */
        .workflow-graph g.node, .workflow-graph g.edge { cursor: help; }
        .workflow-sidebar { max-height: calc(100vh - 9rem); overflow-y: auto; }
    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import {graphviz} from 'd3-graphviz';

        document.addEventListener("DOMContentLoaded", function () {
            const target = document.getElementById('digraphData');
            const source = document.getElementById('digraphSource');
            if (!target || !source) {
                return;
            }
            const dot = source.textContent;
            const XLINK = 'http://www.w3.org/1999/xlink';
            const SVGNS = 'http://www.w3.org/2000/svg';

            // graphviz puts the full description on an <a xlink:title>; promote it to a
            // <title> element so every browser shows it as a native hover tooltip.
            function promoteTooltips() {
                target.querySelectorAll('g.node, g.edge').forEach(g => {
                    const a = g.querySelector('a');
                    const tip = a && (a.getAttributeNS(XLINK, 'title') || a.getAttribute('xlink:title'));
                    if (!tip) {
                        return;
                    }
                    let title = g.querySelector(':scope > title');
                    if (!title) {
                        title = document.createElementNS(SVGNS, 'title');
                        g.insertBefore(title, g.firstChild);
                    }
                    title.textContent = tip;
                });
            }

            // keep graphviz's viewBox but drop the fixed pixel size, so CSS scales the
            // whole graph to fit the card while preserving its aspect ratio.
            function onRendered() {
                const svg = target.querySelector('svg');
                if (svg) {
                    svg.removeAttribute('width');
                    svg.removeAttribute('height');
                    svg.setAttribute('preserveAspectRatio', 'xMidYMid meet');
                }
                promoteTooltips();
            }

            graphviz(target, {useWorker: false, zoom: false})
                .renderDot(dot, onRendered);
        });
    </script>
{% endblock %}

{% block body %}
    {% set digraphData = workflow_digraph(entity, flowCode, 'TB') %}
    {% set isDebug = app.request.query.get('debug', false) %}

    <div class="row g-3 align-items-stretch">
        <div class="col-12 col-xl-9">
            <div class="card workflow-graph-card">
                <div class="card-header">
                    <h2 class="card-title mb-0">{{ flowCode }} Workflow</h2>
                    <div class="card-actions">
                        <span class="badge bg-blue-lt">{{ definition.places|length }} places</span>
                        <span class="badge bg-green-lt">{{ definition.transitions|length }} transitions</span>
                    </div>
                </div>
                <div class="card-body p-2">
                    <div id="digraphData" class="workflow-graph"></div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-3">
            <div class="card workflow-sidebar">
                <div class="card-header">
                    <h3 class="card-title mb-0">Places &amp; Transitions</h3>
                </div>
                <div class="list-group list-group-flush">
                    {{ block('places_with_transitions') }}
                </div>
            </div>
        </div>
    </div>

    {# DOT source for the client-side renderer (and a quick debug peek) #}
    <pre id="digraphSource" class="d-none">{{ digraphData|raw }}</pre>
    {% if isDebug %}
        <pre class="mt-3">{{ digraphData }}</pre>
    {% endif %}
{% endblock %}

{% block places_with_transitions %}
    {% for place in definition.places %}
        {% set placeLabel = survos_workflow_metadata(flowCode, 'label', place) %}
        {% set placeDescription = survos_workflow_metadata(flowCode, 'description', place) %}
        {% set transitions = definition.transitions|filter((t) => place in t.froms) %}
        <div class="list-group-item">
            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-blue-lt">{{ place }}</span>
                {% if placeLabel %}<strong>{{ placeLabel }}</strong>{% endif %}
                <a class="ms-auto small text-secondary hidden-print"
                   href="{{ path('survos_workflow', {flowCode: flowCode, states: place|json_encode}) }}">Set</a>
            </div>
            {% if placeDescription %}
                <div class="text-secondary small mt-1">{{ placeDescription }}</div>
            {% endif %}

            {% if transitions %}
                <ul class="list-unstyled mt-2 mb-0 ps-2 border-start">
                    {% for t in transitions %}
                        {% set transitionLabel = survos_workflow_metadata(flowCode, 'label', t) %}
                        {% set transitionDescription = survos_workflow_metadata(flowCode, 'description', t) %}
                        {% set rp = {commandName: iterateCommand, transition: t.name, marking: place} %}
                        {% if app.request.query.get('className') %}
                            {% set rp = rp|merge({className: app.request.query.get('className')}) %}
                        {% endif %}
                        <li class="mb-1">
                            <i class="fas fa-play text-muted me-1"></i>
                            <a class="fw-bold" href="{{ path('survos_command', rp) }}" title="{{ t.name }}">
                                {{ transitionLabel ?: t.name }}
                            </a>
                            <span class="badge bg-azure-lt ms-1">{{ t.tos|join(', ') }}</span>
                            {% if transitionDescription %}
                                <div class="text-secondary small">{{ transitionDescription }}</div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    {% endfor %}
{% endblock %}
{% block places %}
<h3>{{ flowCode }} States</h3>
<ul class="list list-unstyled">

    {% for place in definition.places|filter( (place) => not (place in definition.initialPlaces) ) %}
        <li><b>{{ place }}</b>:
            <i>
                {{ workflow_metadata(entity, 'description', place, flowCode) ? workflow_metadata(entity, 'description', place, flowCode)|trans : '' }}
            </i>
            <a class="hidden-print" href="{{ path('survos_workflow', {flowCode: flowCode, class: class, states: place|json_encode}) }}">Set</a>
        </li>
    {% endfor %}

</ul>
{% endblock %}

{% block transitions %}
<h3>{{ flowCode }} Transitions</h3>
<ul class="list list-unstyled">
    {% for t in definition.transitions %}
        <li>
            <i>{{ t.name }}</i>
            <span class="pull-right">
                                {{ t.froms|join(',') }}
                                <i class="fa fa-arrow-circle-right"></i>
                -> {{ t.tos|join(',') }}
                            </span>
            <br />
            {{ workflow_metadata(entity, 'description', t, flowCode)  }}
        </li>
    {% endfor %}
</ul>
{% endblock %}

